{
  "name": "my-vite-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:prod": "npm run build:clean && tsc -b && vite build && npm run verify-build",
    "build:prod:docker": "npm run build:clean && tsc -b && vite build --mode production",
    "build:clean": "rimraf dist coverage test-results playwright-report",
    "verify-build": "node scripts/verify-build.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:subscription": "node scripts/test-subscription.js",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:dev": "npm run mobile:build && npx cap run android",
    "mobile:dev:ios": "npm run mobile:build && npx cap run ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:sync": "npx cap sync",
    "test:subscription:headed": "node scripts/test-subscription.js --headed",
    "test:subscription:debug": "node scripts/test-subscription.js --debug"
  },
  "dependencies": {
    "-": "^0.0.1",
    "@capacitor/android": "^7.6.5",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@capacitor/network": "^7.0.4",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^6.1.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "antd": "^5.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-responsive": "^10.0.0",
    "react-router": "^7.15.1",
    "react-virtuoso": "^4.18.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.13.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.14",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
