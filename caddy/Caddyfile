www.sayarat.autos {
    redir https://sayarat.autos{uri} 308
}

sayarat.autos {
    # Enable access logging
    log {
        output stdout
        format console
    }
		
    # Proxy API requests to backend (keep /api prefix)
    handle /api/* {
        reverse_proxy backend:5000
    }

    # Proxy auth requests to backend (for Facebook OAuth callbacks)
    handle /auth/* {
        rewrite * /api{uri}
        reverse_proxy backend:5000
    }

    # Proxy sitemap and SEO files to backend
    handle /sitemap*.xml {
        reverse_proxy backend:5000
    }
    
    handle /robots.txt {
        reverse_proxy backend:5000
    }

    # Proxy all other requests to frontend (catch-all - must be last)
    reverse_proxy frontend:80
}

www.vibed-to-cracked.com {
    redir https://vibed-to-cracked.com{uri} permanent
}

vibed-to-cracked.com {
    encode zstd gzip
    reverse_proxy 173.212.253.103:3002
}

quiz-builder.duckdns.org {
    reverse_proxy 173.212.253.103:3001
}
